rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Convoys: any auth user can read/create; only owner can update/delete
    // Exception: members can update to join (add themselves to memberPhones/members)
    match /convoys/{convoyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        resource.data.ownerUid == request.auth.uid ||
        !("ownerUid" in resource.data) ||
        onlyJoiningAsmember()
      );
      allow delete: if request.auth != null && (
        resource.data.ownerUid == request.auth.uid ||
        !("ownerUid" in resource.data)
      );
    }

    function onlyJoiningAsmember() {
      // Allow update only if the only changed fields are members and memberPhones
      let allowedFields = ['members', 'memberPhones'];
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedFields);
    }

    // Notifications: any authenticated user can read/write (phone-based delivery requires open read)
    match /notifications/{notifId} {
      allow read, write, create: if request.auth != null;
    }

    // Users: any authenticated user can read (needed for phone→uid lookup); only own doc writable
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Announcements subcollection under convoys
    match /convoys/{convoyId}/announcements/{annId} {
      allow read, write: if request.auth != null;
    }
  }
}
