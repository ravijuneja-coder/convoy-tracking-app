rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Convoys: any auth user can read/create; only owner can update/delete
    // Exception: members can update to join (add themselves to memberPhones/members)
    match /convoys/{convoyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Notifications: any authenticated user can read/write (phone-based delivery requires open read)
    match /notifications/{notifId} {
      allow read, write, create: if request.auth != null;
    }

    // Users: allow unauthenticated read for phone→email lookup (forgot password flow)
    // Write restricted to own document only
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Announcements subcollection under convoys
    match /convoys/{convoyId}/announcements/{annId} {
      allow read, write: if request.auth != null;
    }
  }
}
