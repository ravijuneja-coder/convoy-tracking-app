rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Convoys: owner can read/write/delete; any authenticated user can read/update (member check done client-side)
    match /convoys/{convoyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && resource.data.ownerUid == request.auth.uid;
    }

    // Notifications: owner can read/write their own
    match /notifications/{notifId} {
      allow read, write: if request.auth != null && (
        resource == null ||
        resource.data.toUid == request.auth.uid ||
        resource.data.fromUid == request.auth.uid
      );
      allow create: if request.auth != null;
    }

    // Users: each user can read/write their own doc
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Announcements subcollection under convoys
    match /convoys/{convoyId}/announcements/{annId} {
      allow read, write: if request.auth != null;
    }
  }
}
