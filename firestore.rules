rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Convoys: owner can read/write/delete; any authenticated user can read/update (member check done client-side)
    match /convoys/{convoyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Notifications: any authenticated user can read/write (phone-based delivery requires open read)
    match /notifications/{notifId} {
      allow read, write, create: if request.auth != null;
    }

    // Users: any authenticated user can read (needed for phone→uid lookup); only own doc writable
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Announcements subcollection under convoys
    match /convoys/{convoyId}/announcements/{annId} {
      allow read, write: if request.auth != null;
    }
  }
}
